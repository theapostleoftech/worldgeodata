APP_NAME=World Geo Data API
APP_VERSION=0.1.0
API_V1_STR=/api/v1
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/worldgeodata
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
API_KEY_HEADER=X-API-Key
RATE_LIMIT_PER_MINUTE=120
REQUEST_CACHE_TTL_SECONDS=300
# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/worldgeodata
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# API
API_TITLE=World Geo Data API
API_VERSION=v1
DEBUG=false

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# API Keys (for rate limiting)
API_KEY_HEADER=X-API-Key

# Environment
ENVIRONMENT=development
